# Локальная разработка без Docker (браузер → FastAPI напрямую):
NEXT_PUBLIC_API_URL=http://localhost:8000

# SSR в Node при локальном `npm run dev` (опционально, по умолчанию localhost:8000):
# API_URL=http://localhost:8000

# Docker (docker compose): NEXT_PUBLIC_API_URL не нужен — браузер ходит на /api,
# SSR использует API_URL=http://backend:8000 из docker-compose.yml.

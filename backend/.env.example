DATABASE_URL=postgresql+asyncpg://questlog:questlog@localhost:5432/questlog

# AI-генерация квестов через Google Gemini (опционально; без ключа — встроенный fallback)
GEMINI_API_KEY=
# true — при ошибке Gemini вернуть шаблон; false — честная 500 (отладка)
AI_QUEST_ALLOW_FALLBACK=true

# Синхронизация квестов в Obsidian vault
# Локально: абсолютный путь к docs_obsidian в репозитории
OBSIDIAN_VAULT_PATH=/absolute/path/to/docs_obsidian
# Docker compose переопределяет на /vault/docs_obsidian (bind-mount ./docs_obsidian)

# Полночной сброс ежедневных квестов (IANA timezone)
DAILY_RESET_TIMEZONE=Europe/Kyiv

# Telegram-оповещения о дедлайнах и ежедневных квестах
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
